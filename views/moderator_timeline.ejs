<!DOCTYPE html>
<html lang="en">
    <%- include('./partials/header.ejs') %>

<body>
    <%- include('./partials/nav.ejs') %>
    <br>
    <div class="container">  
      
            <% articles.forEach(function(article, index){ %>  
              <% if (index % 4 == 0){ %>
                <div class="row"> 
              <% } %>
              
              <div class="col-md-3">
                <br>
                  <div class="card-deck">
                  <div class="card border-info mb-3 shadow bg-white rounded" style="width: 30rem;">
                    <img class="card-img-top" height="125rem" src="<%= article.Image_Path %>" alt="Card image cap">
                    <div class="card-body text-dark">
                      <h5 class="card-title text-info"><%= article.Title.substr(0,22) %></h5>
                      <p class="card-text"><%= article.Body.substr(0, 100) %></p>
                      <a href="/article/<%=article.ID%>" class="btn btn-primary btn-sm">Read More</a><br> </br>
                      <a href="/article_approve/<%=article.ID%>" class="btn btn-outline-success btn-sm">Approve</a>
                      <a href="/article_delete/<%=article.ID%>" class="btn btn-outline-danger btn-sm">Delete</a>
                    </div>
                    <div class="card-footer text-secondary"><%= article.Created %></div>
                      </div>
                    </div>
                </div>
                <% if ((index+1) % 4 == 0){ %> </div>
                <% } %>
            <%  }) %> 
      </div>    
</body>
</html>