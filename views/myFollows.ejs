<!DOCTYPE html>
<html lang="en">
    <%- include('./partials/head.ejs') %>
<body>
    <%- include('./partials/nav.ejs') %>
    <br> <br>
    <div class="container">
        <div class="row text-center">
            <div class="col-md-2"> </div>
            <div class="col-md-3">
        <table id = "myTable" class="table table-dark table-striped" >
            <thead>
                <tr>
                    <th> Following </th>
                </tr>
            </thead>
            <tbody>
                <% following.forEach(function(following){ %>
                    <tr>
                        <td> <%= following.Name%> </td>
                    </tr>
              <%  }) %>
            </tbody>
        </table>
    </div>
    </div>
    <div class="container">
        <div class="row text-center">
            <div class="col-md-7"> </div>
            <div class="col-md-3">
        <table id = "myTable" class="table table-dark table-striped" >
            <thead>
                <tr>
                    <th> Followers </th>
                </tr>
            </thead>
            <tbody>
                <% followers.forEach(function(follower){ %>
                    <tr>
                        <td> <%= follower.Name%> </td>
                    </tr>
              <%  }) %>
            </tbody>
        </table>
    </div>
    </div>
</body>

</html>
