<!DOCTYPE html>
<html lang="en">
    <%- include('./partials/head.ejs') %>
    <%- include('./partials/nav.ejs') %>
<body>
    <div class="container">  
                <% articles.forEach(function(article){ %>
                    <div class="text-center">
                      <h4><%= article.Name %>'s Profile</h4> 
                      <button type="button" class="btn btn-info">Follow Now!</button> 
                      
                    </div> <br> 
                    <img src="<%= article.Image_Path %>" style="width:100%">
                        <div>
                          <h4 ><%= article.Title %></h4>
                          <p > <%= article.Body.substr(0, 100) %></p>
                          <a href="/article/<%=article.ID%>">Read More</a>
                        </div>
                        <div><%= article.Created %></div>
                        
                      </div>
                      <br>
                      <br>
              <%  }) %>
    </div>      
</body>
</html>